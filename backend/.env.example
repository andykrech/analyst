# Копировать в .env и заполнить значения.

# === Туннель (прокси) ===
# URL прокси для интеграций, которые идут через туннель (например OpenAI Embeddings).
# Формат: socks5://[user:password@]host:port или http://...
# Пусто — прокси не используется.
# TUNNEL_PROXY_URL=

# === OpenAI (эмбеддинги) ===
# Ключ API: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Базовый URL (по умолчанию https://api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com
# Таймаут запроса эмбеддинга (сек)
# OPENAI_EMBEDDING_TIMEOUT_S=30
# Число повторов при сбое (сеть, 5xx, 429)
# OPENAI_EMBEDDING_MAX_RETRIES=3
# Пауза между повторами (сек)
# OPENAI_EMBEDDING_RETRY_DELAY_S=2

# Эмбеддинги: провайдер (openai), модель, размерность, стоимость за 1 токен (для оценки)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# EMBEDDING_COST_PER_TOKEN=0.00002
# Двухуровневая фильтрация: 1) по векторам (rank_score), 2) по итогу ИИ (total_score)
# Порог по векторам (-1..1): ниже — не вызываем ИИ и не сохраняем
# EMBEDDING_QUANTUM_RELEVANCE_THRESHOLD=-1
# Порог по total_score (0..1): ниже — не сохраняем
# QUANTUM_RELEVANCE_THRESHOLD=0

# === Поиск публикаций (шаг publication_retriever в плане) ===
# Лимит результатов на шаг (по умолчанию в коде 50)
# SEARCH_MAX_RESULTS_PUBLICATION=50

# === OpenAlex API (публикации, с 2026 api_key обязателен) ===
OPENALEX_API_KEY=

# === NCBI E-utilities (PubMed) ===
# Имя приложения (без пробелов), контактный email и ключ с https://account.ncbi.nlm.nih.gov
# Без NCBI_EMAIL адаптер PubMed не вызывает API.
# NCBI_TOOL=analyst
NCBI_EMAIL=
NCBI_API_KEY=

# === Перевод квантов ===
# Метод: translator (DeepL и др.) | llm (ИИ)
# QUANTA_TRANSLATION_METHOD=translator
# Макс. число квантов для перевода: 0 = все, >0 = только первые N (отладка, экономия лимитов)
# QUANTA_TRANSLATION_LIMIT=0
# Используемый переводчик при методе translator: deepl
# TRANSLATOR=deepl
# Ключ DeepL (REST API): https://developers.deepl.com
DEEPL_API_KEY=
# Ключ Yandex Cloud Translate (REST); каталог — YANDEX_FOLDER_ID из блока Yandex Search
YANDEX_API_KEY_TRANSLATE=
